{
  "name": "svchat-e2e",
  "private": true,
  "version": "1.0.0",
  "description": "Playwright E2E тесты для SVchat",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep-invert @realtime",
    "test:realtime": "playwright test --grep @realtime",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
